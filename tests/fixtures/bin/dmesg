#!/usr/bin/env bash
set -Eeuo pipefail

case "${OOM_MODE:-none}" in
seen)
    printf '[123.456] Out of memory: Killed process 42 (worker)\n'
    ;;
denied)
    printf 'dmesg: read kernel buffer failed: Operation not permitted\n' >&2
    exit 1
    ;;
*)
    printf '[123.456] normal kernel message\n'
    ;;
esac
