#!/usr/bin/env bash
set -Eeuo pipefail

if [[ "${OPENSSL_MISSING:-0}" == "1" ]]; then
    printf 'openssl intentionally missing\n' >&2
    exit 127
fi

if [[ "${1:-}" == "s_client" && "${2:-}" == "-help" ]]; then
    printf 'Usage: s_client -verify_hostname name\n' >&2
    exit 0
fi

if [[ "${1:-}" == "s_client" ]]; then
    case "${TLS_MODE:-valid}" in
    fail)
        printf 'handshake failure\n' >&2
        exit 1
        ;;
    mismatch)
        printf '%s\n' '-----BEGIN CERTIFICATE-----' 'mock' '-----END CERTIFICATE-----' 'Verify return code: 62 (hostname mismatch)'
        ;;
    *)
        printf '%s\n' '-----BEGIN CERTIFICATE-----' 'mock' '-----END CERTIFICATE-----' 'Verify return code: 0 (ok)'
        ;;
    esac
    exit 0
fi

if [[ "${1:-}" == "x509" ]]; then
    case "${TLS_MODE:-valid}" in
    warning) end="Jul 15 00:00:00 2026 GMT" ;;
    critical) end="Jul 01 00:00:00 2026 GMT" ;;
    expired) end="Jun 01 00:00:00 2026 GMT" ;;
    *) end="Sep 21 00:00:00 2026 GMT" ;;
    esac
    cat <<EOF
subject=CN=example.com
issuer=CN=Example CA
notBefore=Jun 01 00:00:00 2026 GMT
notAfter=$end
EOF
fi
